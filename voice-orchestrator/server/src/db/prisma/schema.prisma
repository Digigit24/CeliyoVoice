generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum VoiceProvider {
  OMNIDIM
  BOLNA
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum ToolAuthType {
  NONE
  API_KEY
  BEARER
  OAUTH
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum PostCallActionType {
  WEBHOOK
}

enum PostCallExecutionStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum CallEventType {
  CALL_STARTED
  CALL_RINGING
  CALL_CONNECTED
  CALL_ENDED
  TRANSCRIPT_UPDATE
  TRANSCRIPT_FINAL
  TOOL_REQUESTED
  TOOL_COMPLETED
  TOOL_FAILED
  AGENT_ACTION
  ERROR
}

enum AgentType {
  VOICE
  CHAT
  HYBRID
}

enum ConversationChannel {
  CHAT_API
  CHAT_WIDGET
  VOICE
  INTERNAL
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL_CALL
  TOOL_RESULT
}

enum ToolSource {
  MANUAL
  SWAGGER_IMPORT
  MCP_IMPORT
}

enum LLMProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  GROQ
  CUSTOM
}

// ── Models ───────────────────────────────────────────────────────────────────

/// Tenant-specific API keys for voice AI providers (apiKey encrypted at rest).
/// tenantId is a plain string (UUID from JWT) — no FK to a local tenants table.
model ProviderCredential {
  id        String        @id @default(uuid())
  tenantId  String
  provider  VoiceProvider
  /// AES-256-GCM encrypted API key.
  apiKey    String
  apiUrl    String?
  config    Json          @default("{}")
  isActive  Boolean       @default(true)
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("provider_credentials")
}

/// Global provider settings (not tenant-specific).
model ProviderConfig {
  id            String        @id @default(uuid())
  provider      VoiceProvider @unique
  displayName   String
  isEnabled     Boolean       @default(true)
  defaultConfig Json          @default("{}")
  /// HMAC secret used to verify incoming webhook signatures.
  webhookSecret String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("provider_configs")
}

/// Agent configuration — supports VOICE, CHAT, and HYBRID agent types.
/// tenantId is a plain string (UUID from JWT) — used to filter, not FK.
model Agent {
  id                 String        @id @default(uuid())
  tenantId           String
  ownerUserId        String
  name               String
  /// Agent type: VOICE (legacy default), CHAT, or HYBRID.
  agentType          AgentType     @default(VOICE) @map("agent_type")
  /// Interface-specific config JSON. Voice agents store voiceLanguage, voiceModel, etc.
  /// Chat agents store llmProvider, llmModel, temperature, etc. Hybrid agents store both.
  typeConfig         Json          @default("{}") @map("type_config")
  /// LLM provider for chat capabilities (e.g. "OPENAI", "ANTHROPIC").
  llmProvider        String?       @map("llm_provider")
  /// LLM model identifier (e.g. "gpt-4o", "claude-sonnet-4-20250514").
  llmModel           String?       @map("llm_model")
  provider           VoiceProvider
  /// Agent ID on the provider's side — null until first sync succeeds.
  providerAgentId    String?
  voiceLanguage      String        @default("en-IN")
  voiceModel         String        @default("female")
  systemPrompt       String        @db.Text
  knowledgebaseId    String?
  /// Array of Tool UUIDs assigned to this agent (legacy — use AgentTool junction table).
  tools              Json          @default("[]")
  workflowId         String?
  maxConcurrentCalls Int           @default(1)
  isActive           Boolean       @default(true)
  metadata           Json?
  /// Full provider-specific config stored as JSON (e.g. full Omnidim agent response).
  providerConfig     Json?         @map("provider_config")
  /// Welcome message spoken at the start of a call.
  welcomeMessage     String?       @map("welcome_message") @db.Text
  /// Call direction type: Incoming or Outgoing.
  callType           String?       @default("Incoming") @map("call_type")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  calls           Call[]
  postCallActions PostCallAction[]
  conversations   Conversation[]
  agentTools      AgentTool[]

  @@unique([tenantId, providerAgentId])
  @@index([tenantId])
  @@index([tenantId, agentType])
  @@map("agents")
}

/// A single voice call — OUTBOUND by default, INBOUND for received calls.
/// tenantId is a plain string (UUID from JWT) — used to filter, not FK.
model Call {
  id             String        @id @default(uuid())
  tenantId       String
  ownerUserId    String
  agentId        String
  phone          String
  direction      CallDirection @default(OUTBOUND)
  provider       VoiceProvider
  providerCallId String?
  status         CallStatus    @default(QUEUED)
  duration           Int?
  transcript         String?       @db.Text
  summary            String?       @db.Text
  recordingUrl       String?
  sentiment          String?
  extractedVariables Json?         @map("extracted_variables")
  cost               Decimal?      @db.Decimal(10, 6)
  /// Array of { toolId, toolName, result } objects.
  toolsUsed          Json          @default("[]")
  metadata           Json?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  agent              Agent              @relation(fields: [agentId], references: [id])
  events             CallEvent[]
  webhookEvents      WebhookEvent[]
  postCallExecutions PostCallExecution[]

  @@index([tenantId, status])
  @@index([tenantId, agentId])
  @@map("calls")
}

/// HTTP tool that can be invoked by an agent during a call or chat.
/// tenantId is a plain string (UUID from JWT) — used to filter, not FK.
model Tool {
  id           String       @id @default(uuid())
  tenantId     String
  ownerUserId  String
  name         String
  description  String
  endpoint     String
  method       HttpMethod   @default(POST)
  headers      Json         @default("{}")
  bodyTemplate Json?
  authType     ToolAuthType @default(NONE)
  /// Encrypted JSON containing auth credentials (API key, token, etc.).
  authConfig   Json         @default("{}")
  timeout      Int          @default(30)
  retries      Int          @default(0)
  isActive     Boolean      @default(true)
  /// JSON Schema for tool input parameters (for LLM function calling).
  inputSchema  Json?        @map("input_schema")
  /// JSON Schema for expected output.
  outputSchema Json?        @map("output_schema")
  /// Grouping category (e.g. "CRM", "Billing", "Internal").
  category     String?
  /// How this tool was created.
  source       ToolSource   @default(MANUAL)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  agentTools AgentTool[]

  @@index([tenantId])
  @@map("tools")
}

/// Raw webhook event received from a voice provider.
model WebhookEvent {
  id               String             @id @default(uuid())
  /// Resolved after processing; null until the call is matched.
  tenantId         String?
  provider         VoiceProvider
  eventType        String
  providerCallId   String?
  callId           String?
  rawPayload       Json
  processedPayload Json?
  status           WebhookEventStatus @default(RECEIVED)
  error            String?
  createdAt        DateTime           @default(now())

  call Call? @relation(fields: [callId], references: [id])

  @@index([providerCallId])
  @@index([tenantId, createdAt])
  @@map("webhook_events")
}

/// Granular events emitted during a call lifecycle.
model CallEvent {
  id        String        @id @default(uuid())
  tenantId  String
  callId    String
  eventType CallEventType
  data      Json
  createdAt DateTime      @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("call_events")
}

/// Post-call outbound action configured per-agent (e.g. fire a webhook when call ends).
model PostCallAction {
  id          String              @id @default(uuid())
  tenantId    String
  agentId     String
  name        String
  type        PostCallActionType  @default(WEBHOOK)
  /// Type-specific config JSON.
  /// WEBHOOK: { url, method, headers, includeRawPayload, secret? }
  config      Json                @default("{}")
  isEnabled   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  agent      Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  executions PostCallExecution[]

  @@index([tenantId, agentId])
  @@map("post_call_actions")
}

/// Execution log for each PostCallAction fired after a call ends.
model PostCallExecution {
  id              String                 @id @default(uuid())
  tenantId        String
  actionId        String
  callId          String?
  status          PostCallExecutionStatus
  requestPayload  Json?
  responseStatus  Int?
  responseBody    String?                @db.Text
  error           String?
  executedAt      DateTime               @default(now())

  action PostCallAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  call   Call?          @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([tenantId, actionId])
  @@index([tenantId, callId])
  @@map("post_call_executions")
}

/// Conversation thread for chat-based agent interactions.
model Conversation {
  id            String             @id @default(uuid())
  tenantId      String
  ownerUserId   String
  agentId       String
  title         String?
  channel       ConversationChannel
  status        ConversationStatus @default(ACTIVE)
  metadata      Json?
  lastMessageAt DateTime?          @map("last_message_at")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  agent    Agent     @relation(fields: [agentId], references: [id])
  messages Message[]

  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@map("conversations")
}

/// Individual message within a conversation.
model Message {
  id             String      @id @default(uuid())
  tenantId       String
  conversationId String
  role           MessageRole
  content        String      @db.Text
  /// Correlation ID for TOOL_CALL / TOOL_RESULT message pairs.
  toolCallId     String?     @map("tool_call_id")
  /// Name of the tool that was called.
  toolName       String?     @map("tool_name")
  /// Token usage for this message.
  tokenCount     Int?        @map("token_count")
  /// Model info, latency, etc.
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// Junction table linking agents to tools with per-agent configuration.
/// Replaces the legacy Json tools array on Agent as the canonical source.
model AgentTool {
  id         String   @id @default(uuid())
  tenantId   String
  agentId    String
  toolId     String
  /// Instruction for LLM on when to use this tool.
  whenToUse  String?  @map("when_to_use") @db.Text
  /// Always include in LLM context regardless of relevance scoring.
  isRequired Boolean  @default(false) @map("is_required")
  /// Ordering hint for tool presentation.
  priority   Int      @default(0)
  /// Per-agent-tool configuration overrides.
  config     Json     @default("{}")
  createdAt  DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tool  Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolId])
  @@index([tenantId, agentId])
  @@map("agent_tools")
}

/// Tenant-specific API keys for LLM providers (apiKey encrypted at rest).
/// Mirrors the ProviderCredential pattern.
model LLMCredential {
  id        String      @id @default(uuid())
  tenantId  String
  provider  LLMProvider
  /// AES-256-GCM encrypted API key.
  apiKey    String
  apiUrl    String?
  config    Json        @default("{}")
  isActive  Boolean     @default(true)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("llm_credentials")
}

/// Tracks LLM token usage and costs per conversation/agent.
model LLMUsage {
  id             String   @id @default(uuid())
  tenantId       String
  agentId        String?
  conversationId String?
  provider       String
  model          String
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  totalTokens    Int      @map("total_tokens")
  cost           Decimal? @db.Decimal(10, 6)
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, agentId])
  @@map("llm_usage")
}

/// Immutable audit trail. userId comes from JWT — no FK to a local user table.
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, resource])
  @@map("audit_logs")
}
